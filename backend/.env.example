# Backend-local native development environment.
# Use this file when running the backend directly from `backend/`.
# Railway production backend should set its variables in Railway, not by copying this file.

APP_ENV=development

# LLM API keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_CLOUD_NANO_API_KEY=your-gemini-image-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
# Optional for future OpenAI-compatible routing
GROQ_API_KEY=your-groq-api-key-here
GCS_BUCKET_NAME=
GCS_SERVICE_ACCOUNT_JSON=
GCS_IMAGE_BASE_URL=

# Image generation
IMAGE_PROVIDER=xai
IMAGE_MODEL_NAME=grok-imagine-image
IMAGE_BASE_URL=https://api.x.ai/v1
IMAGE_API_KEY_ENV=XAI_API_KEY

# IMPORTANT: Do not commit real API keys.

# Pipeline
LECTIO_CONTRACTS_DIR=./contracts
DEFAULT_PAGINATION_LIMIT=20

# Generation admission
GENERATION_MAX_CONCURRENT_PER_USER=2

# v3 execution - model slots
V3_FAST_PROVIDER=anthropic
V3_FAST_MODEL_NAME=claude-haiku-4-5-20251001
V3_FAST_API_KEY_ENV=ANTHROPIC_API_KEY

V3_STANDARD_PROVIDER=anthropic
V3_STANDARD_MODEL_NAME=claude-sonnet-4-6
V3_STANDARD_API_KEY_ENV=ANTHROPIC_API_KEY

V3_PREMIUM_PROVIDER=anthropic
V3_PREMIUM_MODEL_NAME=claude-opus-4-6
V3_PREMIUM_API_KEY_ENV=ANTHROPIC_API_KEY

# v3 Lesson Architect extended thinking
V3_ARCHITECT_THINKING_BUDGET_TOKENS=10000
# v3 Lesson Architect output token ceiling (pydantic-ai Anthropic max_tokens)
V3_ARCHITECT_MAX_TOKENS=8000

# v3 timeouts (seconds)
V3_TIMEOUT_SIGNAL_SECONDS=30
V3_TIMEOUT_CLARIFY_SECONDS=30
V3_TIMEOUT_STAGE1_SECONDS=60
V3_TIMEOUT_STAGE2_SECTION_SECONDS=45
V3_TIMEOUT_ARCHITECT_SECONDS=300
V3_TIMEOUT_SECTION_SECONDS=90
V3_TIMEOUT_QUESTION_SECONDS=60
V3_TIMEOUT_ANSWER_KEY_SECONDS=30
V3_TIMEOUT_REVIEWER_SECONDS=60
V3_TIMEOUT_VISUAL_FRAME_SECONDS=45
V3_TIMEOUT_ASSEMBLY_SECONDS=30
V3_TIMEOUT_COHERENCE_SECONDS=180
V3_TIMEOUT_GENERATION_TOTAL_SECONDS=600

# v3 retries (max retries after first attempt)
V3_RETRY_SIGNAL_MAX=2
V3_RETRY_CLARIFY_MAX=1
V3_RETRY_ARCHITECT_MAX=1
V3_RETRY_SECTION_MAX=1
V3_RETRY_QUESTION_MAX=1
V3_RETRY_ANSWER_KEY_MAX=1
V3_RETRY_REVIEWER_MAX=1
V3_RETRY_VISUAL_MAX=1

# v3 per-generation concurrency
V3_CONCURRENCY_SECTION_MAX=3
V3_CONCURRENCY_QUESTION_MAX=3
V3_CONCURRENCY_VISUAL_MAX=2

# Output
REPORT_OUTPUT_DIR=outputs/reports

# Authentication
GOOGLE_CLIENT_ID=your-google-client-id-here
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
GITHUB_TOKEN=your-github-token-here

# Database
# Runtime uses PostgreSQL. SQLite URLs are still normalized for explicit local dev/test overrides.
DATABASE_URL=postgresql+asyncpg://textbook:textbook@localhost:5432/textbook_agent
DB_ECHO=false
# Development-only SQLite override example:
# DATABASE_URL=sqlite+aiosqlite:///./textbook_agent.db
RUN_MIGRATIONS_ON_STARTUP=true
JSON_LOGS=false
LOG_LEVEL=INFO
PDF_EXPORT_ENABLED=true
PDF_RENDER_BASE_URL=http://localhost:5173
PDF_EXPORT_TIMEOUT_MS=45000
PLAYWRIGHT_TIMEOUT_MS=45000
PDF_TEMP_DIR=outputs/pdf
PDF_MAX_FILE_SIZE_MB=50
PDF_MAX_PAGE_COUNT=200

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Public Lesson Builder links emitted by the backend in native dev.
LESSON_BUILDER_PUBLIC_URL=http://localhost:5173


# Railway production example:
# APP_ENV=production
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
# GOOGLE_CLIENT_ID=your-google-client-id-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# FRONTEND_ORIGIN=https://your-frontend.example.com
# LESSON_BUILDER_PUBLIC_URL=https://your-frontend.example.com
# PDF_RENDER_BASE_URL=https://your-frontend.example.com
# LECTIO_CONTRACTS_DIR=/app/backend/contracts
# RUN_MIGRATIONS_ON_STARTUP=true
# JSON_LOGS=true
# LOG_LEVEL=INFO
