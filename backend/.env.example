# Backend-local native development environment.
# Use this file when running the backend directly from `backend/`.
# Docker/Compose uses the repo-root `.env` instead.

APP_ENV=development

# Core auth/runtime
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
JWT_SECRET_KEY=replace-with-a-secure-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Provider API keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Provider/model routing
PIPELINE_FAST_PROVIDER=anthropic
PIPELINE_FAST_MODEL_NAME=claude-sonnet-4-6
PIPELINE_FAST_API_KEY_ENV=ANTHROPIC_API_KEY

PIPELINE_STANDARD_PROVIDER=anthropic
PIPELINE_STANDARD_MODEL_NAME=claude-sonnet-4-6
PIPELINE_STANDARD_API_KEY_ENV=ANTHROPIC_API_KEY

# Planning model routing
# PLANNING_BRIEF_INTERPRETER_PROVIDER=anthropic
# PLANNING_BRIEF_INTERPRETER_MODEL_NAME=claude-haiku-4-5-20251001
# PLANNING_BRIEF_INTERPRETER_API_KEY_ENV=ANTHROPIC_API_KEY

# Optional OpenAI-compatible example
# PIPELINE_FAST_PROVIDER=openai_compatible
# PIPELINE_FAST_MODEL_NAME=llama3-8b-8192
# PIPELINE_FAST_BASE_URL=https://api.groq.com/openai/v1
# PIPELINE_FAST_API_KEY_ENV=GROQ_API_KEY

LLM_MAX_TOKENS=4096
LECTIO_CONTRACTS_DIR=./contracts
DEFAULT_PAGINATION_LIMIT=20

# Generation admission
GENERATION_MAX_CONCURRENT_PER_USER=2

# Runtime concurrency by mode
PIPELINE_CONCURRENCY_DRAFT_SECTION_MAX=6
PIPELINE_CONCURRENCY_DRAFT_DIAGRAM_MAX=2
PIPELINE_CONCURRENCY_DRAFT_QC_MAX=6
PIPELINE_CONCURRENCY_BALANCED_SECTION_MAX=4
PIPELINE_CONCURRENCY_BALANCED_DIAGRAM_MAX=2
PIPELINE_CONCURRENCY_BALANCED_QC_MAX=4
PIPELINE_CONCURRENCY_STRICT_SECTION_MAX=3
PIPELINE_CONCURRENCY_STRICT_DIAGRAM_MAX=1
PIPELINE_CONCURRENCY_STRICT_QC_MAX=3

# Whole-generation timeout
PIPELINE_TIMEOUT_GENERATION_BASE_SECONDS=120
PIPELINE_TIMEOUT_GENERATION_PER_SECTION_SECONDS=90
PIPELINE_TIMEOUT_GENERATION_CAP_SECONDS=900

# Node timeout budgets
PIPELINE_TIMEOUT_CURRICULUM_SECONDS=60
PIPELINE_TIMEOUT_CONTENT_CORE_SECONDS=180
PIPELINE_TIMEOUT_CONTENT_PRACTICE_SECONDS=120
PIPELINE_TIMEOUT_CONTENT_ENRICHMENT_SECONDS=90
PIPELINE_TIMEOUT_CONTENT_REPAIR_SECONDS=120
PIPELINE_TIMEOUT_FIELD_REGEN_SECONDS=60
PIPELINE_TIMEOUT_QC_SECONDS=60
PIPELINE_TIMEOUT_DIAGRAM_INNER_SECONDS=45
PIPELINE_TIMEOUT_DIAGRAM_NODE_BUDGET_SECONDS=60

# Section rerender budgets
PIPELINE_RERENDER_DRAFT_SECTION_MAX=1
PIPELINE_RERENDER_BALANCED_SECTION_MAX=2
PIPELINE_RERENDER_STRICT_SECTION_MAX=3

# LLM retry budgets
PIPELINE_RETRY_CURRICULUM_MAX_ATTEMPTS=2
PIPELINE_RETRY_CONTENT_CORE_MAX_ATTEMPTS=2
PIPELINE_RETRY_CONTENT_PRACTICE_MAX_ATTEMPTS=2
PIPELINE_RETRY_CONTENT_ENRICHMENT_MAX_ATTEMPTS=2
PIPELINE_RETRY_CONTENT_REPAIR_MAX_ATTEMPTS=2
PIPELINE_RETRY_FIELD_REGEN_MAX_ATTEMPTS=2
PIPELINE_RETRY_QC_MAX_ATTEMPTS=2
PIPELINE_RETRY_DIAGRAM_MAX_ATTEMPTS=1

# Database
DATABASE_URL=postgresql+asyncpg://textbook:textbook@localhost:5432/textbook_agent
DB_ECHO=false
RUN_MIGRATIONS_ON_STARTUP=true

# Logging
JSON_LOGS=false
LOG_LEVEL=INFO

# Native frontend URLs
FRONTEND_ORIGIN=http://localhost:5173
LESSON_BUILDER_PUBLIC_URL=http://localhost:5173
PDF_RENDER_BASE_URL=http://localhost:5173

# Outputs and local image storage
REPORT_OUTPUT_DIR=outputs/reports
PDF_TEMP_DIR=outputs/pdf
IMAGE_BASE_URL=http://localhost:8000/images

# Production image storage
GCS_BUCKET_NAME=textbook-diagrams

# PDF export
PDF_EXPORT_ENABLED=true
PDF_EXPORT_TIMEOUT_MS=45000
PLAYWRIGHT_TIMEOUT_MS=45000
PDF_MAX_FILE_SIZE_MB=50
PDF_MAX_PAGE_COUNT=200

# Railway production example:
# APP_ENV=production
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
# FRONTEND_ORIGIN=https://your-frontend.example.com
# LESSON_BUILDER_PUBLIC_URL=https://your-frontend.example.com
# PDF_RENDER_BASE_URL=https://your-frontend.example.com
# JSON_LOGS=true
# LOG_LEVEL=INFO
