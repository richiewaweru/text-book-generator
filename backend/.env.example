ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# IMPORTANT: Do not commit real API keys.

# Pipeline model routing (overrides defaults in pipeline.providers.registry)
# Preferred (route-based) overrides:
#MODEL_TEXT_FAST_PROVIDER=anthropic
#MODEL_TEXT_FAST_NAME=claude-haiku-4-5-20251001
#MODEL_TEXT_STANDARD_PROVIDER=anthropic
#MODEL_TEXT_STANDARD_NAME=claude-sonnet-4-6
#MODEL_TEXT_CREATIVE_PROVIDER=anthropic
#MODEL_TEXT_CREATIVE_NAME=claude-sonnet-4-6

LLM_MAX_TOKENS=4096

# Pipeline
LECTIO_CONTRACTS_DIR=./contracts
MAX_RETRIES=2
RETRY_BASE_DELAY=1.0
QUALITY_CHECK_ENABLED=true
MAX_QUALITY_RERUNS=2
TEMPERATURE=0.3
CODE_LINE_SOFT_LIMIT=80
CODE_LINE_HARD_LIMIT=300
DEFAULT_PAGINATION_LIMIT=20

# Output
OUTPUT_DIR=outputs/
OUTPUT_FORMAT=html

# Authentication
GOOGLE_CLIENT_ID=your-google-client-id-here
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite+aiosqlite:///./textbook_agent.db

# CORS
FRONTEND_ORIGIN=http://localhost:5173
