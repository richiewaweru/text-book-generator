# Frontend-local native development environment.
# Use this file when running the frontend directly from `frontend/`.
# Docker/Compose uses the repo-root `.env` instead.

# Canonical browser API base for native frontend development.
PUBLIC_API_URL=http://localhost:8000

# Google sign-in for the browser runtime.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional dev-only Vite proxy override.
# VITE_API_TARGET=http://localhost:8000
