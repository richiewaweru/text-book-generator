{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewReport",
  "type": "object",
  "required": ["summary", "overall_risk", "decision", "findings"],
  "properties": {
    "summary": {
      "type": "string"
    },
    "overall_risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "decision": {
      "type": "string",
      "enum": ["advisory-pass", "advisory-concerns"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "severity", "category", "description", "recommendation"],
        "properties": {
          "title": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "category": {
            "type": "string",
            "enum": ["bug-risk", "architecture-compliance", "test-gap"]
          },
          "file_path": {
            "type": ["string", "null"]
          },
          "line": {
            "type": ["integer", "null"]
          },
          "description": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
